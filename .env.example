# Configurações do servidor
PORT=3001

# Configurações do MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=igreja_crista

# JWT Secret (troque por uma string segura em produção)
JWT_SECRET=sua_chave_secreta_aqui
JWT_EXPIRES_IN=7d

# Configurações do Resend (Email)
RESEND_API_KEY=seu_api_key_do_resend_aqui
# IMPORTANTE: Use 'onboarding@resend.dev' para testes ou configure seu domínio verificado
RESEND_FROM_EMAIL=onboarding@resend.dev

# URL do Frontend (para links de reset de senha)
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
